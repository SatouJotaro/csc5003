## ✅ C++ 完整代码

```cpp
#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int T;
    cin >> T;
    
    while (T--) {
        string stamp, target;
        cin >> stamp >> target;
        
        int n = (int)target.size();
        int m = (int)stamp.size();
        string t = target;  // 工作字符串，逐步变成???...?
        
        bool changed = true;
        while (changed) {
            changed = false;
            for (int i = 0; i <= n - m; i++) {
                bool valid   = true;   // stamp能否在位置i反印
                bool hasNonQ = false;  // 至少有一个非?字符（保证有进展）
                
                for (int j = 0; j < m; j++) {
                    if (t[i+j] == '?') continue;          // ?可以忽略
                    if (t[i+j] != stamp[j]) {             // 字符不匹配
                        valid = false; break;
                    }
                    hasNonQ = true;  // 找到至少一个实际匹配
                }
                
                if (valid && hasNonQ) {
                    // 反印：把这段全变成?
                    for (int j = 0; j < m; j++) t[i+j] = '?';
                    changed = true;
                }
            }
        }
        
        // 检查是否全变成?
        bool allQ = (t == string(n, '?'));
        cout << (allQ ? "YES" : "NO") << "\n";
    }
    
    return 0;
}
```

---

## 🔍 验证样例

```
stamp="abc", target="ababc"
t="ababc" → i=2匹配"abc" → t="ab???"
t="ab???" → i=0匹配"ab?" → t="?????"
全是? → YES ✓

stamp="ab", target="ba"
t="ba" → i=0:"ba"中'b'≠'a' → 无匹配
t="ba" 非全? → NO ✓
```

